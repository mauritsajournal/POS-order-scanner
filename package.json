{
  "name": "scanorder",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "dev:mobile": "turbo dev --filter=@scanorder/mobile",
    "dev:web": "turbo dev --filter=@scanorder/web",
    "dev:api": "turbo dev --filter=@scanorder/api",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "db:generate": "pnpm --filter @scanorder/db generate",
    "db:push": "pnpm --filter @scanorder/db push",
    "db:seed": "pnpm --filter @scanorder/db seed",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "prettier": "^3.5.0"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22"
  }
}
